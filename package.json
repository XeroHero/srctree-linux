{
  "name": "sourcetree-linux",
  "version": "1.0.0",
  "description": "A SourceTree-like Git GUI for Linux",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder",
    "dist": "vite build && electron-builder"
  },
  "keywords": ["electron", "git", "gui", "sourcetree", "linux"],
  "author": "SourceTree Linux",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simple-git": "^3.25.0"
  },
  "build": {
    "appId": "com.sourcetree.linux",
    "productName": "SourceTree Linux",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
